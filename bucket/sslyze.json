    "bin": "sslyze.exe",
    "installer": {
        "script": [
            "$subdir = gci -Path $dir -Directory | where { $_.Name -like 'exe.win-amd64-*' -or $_.Name -like 'sslyze-*-exe' } | select -First 1",
            "if ($subdir) { gci -Path $subdir.FullName -Force | foreach { Move-Item -Path $_.FullName -Destination $dir -Force } ; Remove-Item $subdir.FullName -Recurse -Force }"
        ]
    },
